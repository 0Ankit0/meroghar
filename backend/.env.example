# MeroGhar Backend Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# REQUIRED SETTINGS (Must be configured for the app to run)
# =============================================================================

# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://meroghar:meroghar_dev_password@localhost:5432/meroghar_dev

# pgAdmin Configuration (for database management GUI)
# Access pgAdmin at: http://localhost:5050
PGADMIN_DEFAULT_EMAIL=admin@meroghar.com
PGADMIN_DEFAULT_PASSWORD=meroghar_admin_password

# Authentication & Security
# IMPORTANT: Generate secure random strings for production
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-random-secret-in-production-min-32-chars
JWT_SECRET_KEY=change-this-to-different-random-secret-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis Configuration (for caching and Celery)
REDIS_URL=redis://localhost:6379/0

# Application Environment
ENVIRONMENT=development  # Options: development, staging, production
DEBUG=True  # Set to False in production

# =============================================================================
# OPTIONAL SETTINGS (Can be added as needed)
# =============================================================================

# AWS S3 Configuration (for document storage)
# Leave blank to disable S3 storage (files stored locally)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=meroghar-documents

# Payment Gateway: Stripe
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_PUBLISHABLE_KEY=pk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# Payment Gateway: Razorpay
# Get test keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# SMS/Twilio Configuration (for SMS notifications)
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications (Firebase Cloud Messaging)
# Get server key from: Firebase Console > Project Settings > Cloud Messaging
FCM_SERVER_KEY=AAAA...

# Sentry Error Monitoring (for production error tracking)
# Get DSN from: https://sentry.io/settings/projects/
SENTRY_DSN=https://...@sentry.io/...
SENTRY_TRACES_SAMPLE_RATE=1.0  # 0.0 to 1.0 (percentage of traces to capture)
SENTRY_ENVIRONMENT=development

# Email Configuration (for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@meroghar.com
SMTP_FROM_NAME=MeroGhar

# CORS Configuration (for frontend access)
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# File Upload Limits
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# Logging Configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/app.log

# =============================================================================
# TESTING (for running tests)
# =============================================================================

# Test Database (used only during pytest)
TEST_DATABASE_URL=postgresql://meroghar:meroghar_dev_password@localhost:5432/meroghar_test_db

# =============================================================================
# DOCKER CONFIGURATION (when running with docker-compose)
# =============================================================================

# When using docker-compose, these may be overridden:
# - DATABASE_URL uses container name: postgresql://meroghar:meroghar_dev_password@postgres:5432/meroghar_dev
# - REDIS_URL uses container name: redis://redis:6379/0

# =============================================================================
# NOTES
# =============================================================================

# 1. Copy this file to .env in the same directory
#    cp .env.example .env

# 2. Update all REQUIRED settings with your actual values

# 3. For production:
#    - Generate secure random SECRET_KEY and JWT_SECRET_KEY
#    - Set ENVIRONMENT=production
#    - Set DEBUG=False
#    - Configure Sentry for error monitoring
#    - Use strong database passwords
#    - Enable SSL/TLS for all external services

# 4. Never commit .env file to version control
#    (.env is in .gitignore)

# 5. For local development, you can leave most OPTIONAL settings blank
#    The app will work with just the REQUIRED settings
